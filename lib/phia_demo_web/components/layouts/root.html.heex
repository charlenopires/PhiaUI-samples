<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="PhiaDemo" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <%!-- Anti-FOUC: apply .dark class before stylesheet to avoid theme flash --%>
    <script>
      (function() {
        var mode = localStorage.getItem('phia-mode') || localStorage.getItem('phia-theme');
        if (mode === 'dark' || (!mode && matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.classList.add('dark');
        }
        var colorTheme = localStorage.getItem('phia-color-theme');
        if (colorTheme) {
          document.documentElement.setAttribute('data-phia-theme', colorTheme);
        }
      })();
    </script>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script src="https://cdn.jsdelivr.net/npm/echarts@5/dist/echarts.min.js"></script>
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <a href="#main-content" class="sr-only focus:not-sr-only focus:fixed focus:top-2 focus:left-2 focus:z-[100] focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground focus:text-sm focus:font-medium">
      Skip to content
    </a>
    <.toast id="phia-toast-viewport" />
    {@inner_content}
  </body>
</html>
